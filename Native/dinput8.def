; dinput8.dll proxy — export definition
; Ensures the export name is undecorated (no _@N suffix from stdcall)
; Chain-load: eqgame.exe → us → dinput8_dalaya.dll → system32\dinput8.dll
LIBRARY dinput8
EXPORTS
    DirectInput8Create
    DllCanUnloadNow = ProxyDllCanUnloadNow PRIVATE
    DllGetClassObject = ProxyDllGetClassObject PRIVATE
    DllRegisterServer = ProxyDllRegisterServer PRIVATE
    DllUnregisterServer = ProxyDllUnregisterServer PRIVATE
    GetdfDIJoystick = ProxyGetdfDIJoystick
